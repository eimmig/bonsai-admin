{
  "info": {
    "name": "Bonsai Admin — Todos os Endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token",   "value": "" }
  ],
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@utfpr.edu.br\",\n  \"password\": \"admin1\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Usuários",
      "item": [
        {
          "name": "Registrar usuário",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/register", "host": ["{{baseUrl}}"], "path": ["users","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"novo@utfpr.edu.br\",\n  \"password\": \"senha123\"\n}"
            }
          }
        },
        {
          "name": "Ativar usuário",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/:id/activate", "host": ["{{baseUrl}}"], "path": ["users",":id","activate"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Atribuir roles",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/users/:id/roles", "host": ["{{baseUrl}}"], "path": ["users",":id","roles"], "variable": [{ "key": "id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roles\": [\"OPERATOR\"]\n}"
            }
          }
        },
        {
          "name": "Listar usuários",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/users?page=0&size=10&sort=createdAt,desc",
              "host": ["{{baseUrl}}"], "path": ["users"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "createdAt,desc" }
              ]
            }
          }
        },
        {
          "name": "Buscar usuário por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/:id", "host": ["{{baseUrl}}"], "path": ["users",":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Listar pedidos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/orders?page=0&size=10",
              "host": ["{{baseUrl}}"], "path": ["orders"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "status", "value": "", "disabled": true },
                { "key": "customerId", "value": "", "disabled": true },
                { "key": "dateFrom", "value": "", "disabled": true },
                { "key": "dateTo", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Buscar pedido por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/:id", "host": ["{{baseUrl}}"], "path": ["orders",":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Atualizar status do pedido",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/orders/:id/status", "host": ["{{baseUrl}}"], "path": ["orders",":id","status"], "variable": [{ "key": "id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PAGO\"\n}"
            }
          }
        },
        {
          "name": "Histórico de status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/:id/history", "host": ["{{baseUrl}}"], "path": ["orders",":id","history"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Totalizadores por status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/summary", "host": ["{{baseUrl}}"], "path": ["orders","summary"] }
          }
        },
        {
          "name": "IDs de clientes com pedidos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/orders/customers?page=0&size=20",
              "host": ["{{baseUrl}}"], "path": ["orders","customers"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Anexos",
      "item": [
        {
          "name": "Listar anexos do pedido",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/:orderId/attachments", "host": ["{{baseUrl}}"], "path": ["orders",":orderId","attachments"], "variable": [{ "key": "orderId", "value": "" }] }
          }
        },
        {
          "name": "Upload de anexo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/orders/:orderId/attachments?type=NOTA_FISCAL",
              "host": ["{{baseUrl}}"], "path": ["orders",":orderId","attachments"],
              "query": [{ "key": "type", "value": "NOTA_FISCAL" }],
              "variable": [{ "key": "orderId", "value": "" }]
            },
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            }
          }
        },
        {
          "name": "Download de anexo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/attachments/:id/download", "host": ["{{baseUrl}}"], "path": ["attachments",":id","download"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    }
  ]
}
